generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── COMPANY DOMAIN ──────────────────────────────

model Company {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  email     String?
  inn       String?  // INN/Tax ID
  logo      String?
  isActive  Boolean  @default(true)

  users     User[]
  warehouses Warehouse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── PRODUCT DOMAIN ──────────────────────────────

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Folder {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Unit {
  id        String    @id @default(cuid())
  name      String    // "Dona (rulon)", "m²", "Karobka"
  shortName String    // "dona", "m²", "karobka"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id             String   @id @default(cuid())
  name           String
  sku            String?  @unique
  barcode        String?  @unique
  barcodeType    String   @default("EAN13") // EAN13, Code128, UPC
  imageUrl       String?
  weight         Float?

  sellPrice      Float    @default(0)
  wholesalePrice Float    @default(0)
  minPrice       Float    @default(0)

  categoryId     String?
  category       Category? @relation(fields: [categoryId], references: [id])
  folderId       String?
  folder         Folder?   @relation(fields: [folderId], references: [id])
  unitId         String?
  unit           Unit?     @relation(fields: [unitId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stockEntries        StockEntry[]
  stockThresholds    StockThreshold[]
  variants           ProductVariant[]
  transferItems       TransferItem[]
  inventoryAuditItems InventoryAuditItem[]
  priceListItems      PriceListItem[]
  purchaseItems       PurchaseItem[]
  orderItems          OrderItem[]
  batches             ProductBatch[]
  deliveryItems       DeliveryItem[]
  forecasts           DemandForecast[]

  @@index([categoryId])
  @@index([name])
}

// ─── PRODUCT VARIANTS DOMAIN ─────────────────────

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String   // "Oq", "Qora", "Moviy", "S" "M" "L"
  sku         String?  @unique
  price      Float    @default(0)
  costPrice  Float    @default(0)
  quantity   Float    @default(0)
  imageUrl   String?
  isActive   Boolean  @default(true)

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([productId])
  @@index([sku])
}

model VariantOption {
  id        String   @id @default(cuid())
  name      String   // "Rang", "O'lcham", "Material"
  values    String   // JSON array: ["Oq","Qora","Qizil"]

  createdAt DateTime  @default(now())

  @@index([name])
}

// ─── WAREHOUSE DOMAIN ────────────────────────────

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  address   String?
  district  String?
  latitude  Float?
  longitude Float?
  isDefault Boolean  @default(false)

  companyId String?
  company   Company?  @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockEntries     StockEntry[]
  stockThresholds StockThreshold[]
  transfersFrom    Transfer[]          @relation("TransferFrom")
  transfersTo      Transfer[]          @relation("TransferTo")
  inventoryAudits  InventoryAudit[]
  inventoryAuditItems InventoryAuditItem[]
  purchases        Purchase[]
  orders           Order[]
  users            User[]
  userRequests     UserRequest[]
  batches          ProductBatch[]
  deliveries       Delivery[]
}

model StockEntry {
  id          String   @id @default(cuid())
  quantity    Float    @default(0)
  reserved    Float    @default(0)
  costPrice   Float    @default(0)

  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, warehouseId])
  @@index([warehouseId])
}

// ─── STOCK THRESHOLD DOMAIN (OMBOR ORNATI) ─────────

model StockThreshold {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse  Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  minStock   Float    @default(0)
  enabled    Boolean  @default(true)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([productId, warehouseId])
  @@index([warehouseId])
}

// ─── TRANSFER DOMAIN ─────────────────────────────

enum TransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

model Transfer {
  id                String         @id @default(cuid())
  docNumber         String         @unique
  date              DateTime       @default(now())
  responsiblePerson String?
  status            TransferStatus @default(PENDING)

  fromWarehouseId   String
  fromWarehouse     Warehouse      @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouseId     String
  toWarehouse       Warehouse      @relation("TransferTo", fields: [toWarehouseId], references: [id])

  items             TransferItem[]

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([date])
}

model TransferItem {
  id         String   @id @default(cuid())
  quantity   Float

  transferId String
  transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])

  @@index([transferId])
}

// ─── INVENTORY AUDIT DOMAIN ─────────────────────

enum AuditStatus {
  IN_PROGRESS
  COMPLETED
}

model InventoryAudit {
  id                String      @id @default(cuid())
  docNumber         String      @unique
  date              DateTime    @default(now())
  responsiblePerson String?
  status            AuditStatus @default(IN_PROGRESS)

  warehouseId       String
  warehouse         Warehouse   @relation(fields: [warehouseId], references: [id])

  items             InventoryAuditItem[]

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([warehouseId])
}

model InventoryAuditItem {
  id          String         @id @default(cuid())
  expectedQty Float          @default(0)
  actualQty   Float          @default(0)
  difference  Float          @default(0)
  reason      String?

  auditId     String
  audit       InventoryAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  productId   String
  product     Product        @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id])

  @@index([auditId])
  @@index([productId])
  @@index([warehouseId])
}

// ─── PRICE LIST DOMAIN ──────────────────────────

enum PriceListType {
  SALE
  PURCHASE
}

model PriceList {
  id        String        @id @default(cuid())
  name      String
  type      PriceListType @default(SALE)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  items     PriceListItem[]
}

model PriceListItem {
  id          String    @id @default(cuid())
  price       Float

  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])

  @@unique([priceListId, productId])
}

// ─── CUSTOMER DOMAIN ────────────────────────────

model CustomerGroup {
  id              String   @id @default(cuid())
  name            String
  description     String?
  defaultDiscount Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customers       Customer[]
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

model Customer {
  id          String         @id @default(cuid())
  fullName    String
  companyName String?
  phone       String?
  address     String?
  latitude    Float?
  longitude   Float?
  region      String?
  status      CustomerStatus @default(ACTIVE)
  balanceUSD  Float          @default(0)
  balanceUZS  Float          @default(0)
  creditLimit Float          @default(0) // Credit limit in USD
  creditUsed  Float          @default(0) // Used credit

  groupId     String?
  group       CustomerGroup? @relation(fields: [groupId], references: [id])

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  transactions CustomerTransaction[]
  orders       Order[]
  deliveries   Delivery[]
  routeStops   DeliveryRouteStop[]
  contracts    Contract[]
  loyaltyAccount LoyaltyAccount?

  @@index([groupId])
  @@index([fullName])
}

enum TransactionType {
  DEBT
  PAYMENT
}

model CustomerTransaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Float
  currency    String          @default("USD") // USD or UZS
  date        DateTime        @default(now())
  dueDate     DateTime?
  description String?

  customerId  String
  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt   DateTime        @default(now())

  @@index([customerId])
  @@index([date])
}

// ─── SUPPLIER DOMAIN ────────────────────────────

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

model Supplier {
  id            String         @id @default(cuid())
  name          String
  contactPerson String?
  phone         String?
  category      String?
  status        SupplierStatus @default(ACTIVE)
  balanceUSD    Float          @default(0)
  balanceUZS    Float          @default(0)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  transactions  SupplierTransaction[]
  purchases     Purchase[]
  batches       ProductBatch[]
  contracts     Contract[]

  @@index([name])
}

model SupplierTransaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Float
  currency    String          @default("USD")
  date        DateTime        @default(now())
  dueDate     DateTime?
  description String?

  supplierId  String
  supplier    Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  createdAt   DateTime        @default(now())

  @@index([supplierId])
  @@index([date])
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum SubscriptionStatus {
  PENDING
  PAID
  OVERDUE
}

enum UserRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model UserRequest {
  id           String            @id @default(cuid())
  name         String
  phone        String            @unique
  email        String?
  password     String
  warehouseId  String?
  warehouse    Warehouse?        @relation(fields: [warehouseId], references: [id])
  status       UserRequestStatus @default(PENDING)
  note         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([status])
  @@index([warehouseId])
}

model User {
  id          String   @id @default(cuid())
  name        String?
  email       String?  @unique
  phone       String?  @unique
  password    String
  role        UserRole @default(STAFF)
  isActive    Boolean  @default(true)
  permissions String[] @default([])

  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id])

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions     Subscription[]
  userNotifications UserNotification[]
  settings          UserSettings?
  telegramChat      TelegramChat?
  salesAgent        SalesAgent?

  @@index([warehouseId])
  @@index([phone])
}

// ─── USER SETTINGS ───────────────────────────────

model UserSettings {
  id                  String  @id @default(cuid())
  userId              String  @unique
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailNotifications  Boolean @default(true)
  pushNotifications   Boolean @default(false)
  lowStockAlerts      Boolean @default(true)
  orderNotifications  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id        String   @id @default(cuid())
  amount    Float
  currency  String   @default("USD")
  dueDate   DateTime
  isPaid    Boolean  @default(false)
  paidDate  DateTime?
  note      String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([dueDate])
}

// ─── PURCHASE DOMAIN (KIRIM) ────────────────────

enum PurchaseStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

model Purchase {
  id          String         @id @default(cuid())
  docNumber   String         @unique
  date        DateTime       @default(now())
  supplierId  String
  supplier    Supplier       @relation(fields: [supplierId], references: [id])
  warehouseId String
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id])
  totalAmount Float          @default(0)
  status      PurchaseStatus @default(DRAFT)
  notes       String?

  items       PurchaseItem[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([supplierId])
  @@index([warehouseId])
  @@index([date])
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Float
  price      Float    // Cost price at the time of purchase
  total      Float

  @@index([purchaseId])
  @@index([productId])
}

// ─── SALES DOMAIN (SAVDO) ───────────────────────

enum OrderStatus {
  DRAFT
  COMPLETED
  CANCELLED
  RETURNED
}

model Order {
  id            String      @id @default(cuid())
  docNumber     String      @unique
  date          DateTime    @default(now())
  customerId    String?
  customer      Customer?   @relation(fields: [customerId], references: [id])
  warehouseId   String
  warehouse     Warehouse   @relation(fields: [warehouseId], references: [id])
  totalAmount   Float       @default(0)
  discount      Float       @default(0)
  finalAmount   Float       @default(0)
  status        OrderStatus @default(COMPLETED)
  paymentMethod String?     // CASH, CARD, TRANSFER
  notes         String?

  items         OrderItem[]
  delivery      Delivery?
  commission    Commission?
  agentId       String?
  agent         SalesAgent? @relation(fields: [agentId], references: [id])

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([customerId])
  @@index([warehouseId])
  @@index([date])
}

model OrderItem {
  id        String        @id @default(cuid())
  orderId   String
  order     Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product      @relation(fields: [productId], references: [id])
  quantity  Float
  price     Float         // Selling price at the time of sale
  total     Float
  batchId   String?
  batch     ProductBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@index([batchId])
}

// ─── CASHBOX DOMAIN (KASSA) ─────────────────────

enum CashboxType {
  CASH
  CARD
  BANK
}

model Cashbox {
  id           String            @id @default(cuid())
  name         String            // "Asosiy Kassa", "Humo", "Uzcard", "Tranzit"
  type         CashboxType       @default(CASH)
  currency     String            @default("UZS")
  balance      Float             @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  transactions CashTransaction[]
}

enum CashTransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

model CashTransaction {
  id          String              @id @default(cuid())
  cashboxId   String
  cashbox     Cashbox             @relation(fields: [cashboxId], references: [id], onDelete: Cascade)
  type        CashTransactionType
  amount      Float
  date        DateTime            @default(now())
  referenceId String?             // Order ID or Purchase ID etc
  description String?

  createdAt   DateTime            @default(now())

  @@index([cashboxId])
  @@index([date])
}

// ─── EXCHANGE RATE ──────────────────────────────

model ExchangeRate {
  id        String   @id @default(cuid())
  currency  String   @unique @default("USD")
  rate      Float    // masalan: 12500
  date      DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── ADMIN NOTIFICATIONS ─────────────────────────

model AdminNotification {
  id        String   @id @default(cuid())
  type      String   // "new_user_request" | "order" | "stock_low" | "info"
  title     String
  message   String
  link      String?  // Click qilganda qaerga o'tishi
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isRead])
  @@index([createdAt])
}

// ─── ACTIVITY LOG (FAOLIANAT KUNDALIGI) ─────────

enum ActivityType {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
}

model ActivityLog {
  id          String      @id @default(cuid())
  userId      String
  userName   String?
  userRole   String?
  type        ActivityType
  entity     String      // "Order", "Product", "Customer" etc.
  entityId   String?
  action     String      // "created order SL-000001", "updated product X", "deleted customer Y"
  details    String?     // JSON string containing changes
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime   @default(now())

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
}

// ─── WEBHOOKS & API KEYS ─────────────────────────

enum WebhookEvent {
  ORDER_CREATED
  ORDER_UPDATED
  ORDER_CANCELLED
  CUSTOMER_CREATED
  PRODUCT_LOW_STOCK
}

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  key         String   @unique // Hashed API key
  prefix      String   // First 8 chars for display (sk_live_...)
  permissions String[]  // ["read_orders", "write_products", etc.]
  expiresAt   DateTime?
  lastUsedAt DateTime?
  isActive    Boolean  @default(true)
  createdBy   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
}

model Webhook {
  id          String         @id @default(cuid())
  name        String
  url         String         // Webhook URL
  secret      String?        // Secret for signature verification
  events      WebhookEvent[] // Events to trigger on
  isActive    Boolean        @default(true)
  lastTriggeredAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

@@index([isActive])
}

// ─── USER NOTIFICATIONS ──────────────────────────

model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "product_transfer" | "info" | "warning"
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

   @@index([userId])
   @@index([isRead])
   @@index([createdAt])
}

// ─── TELEGRAM BOT INTEGRATION ─────────────────────

model TelegramBotConfig {
  id          String   @id @default(cuid())
  botToken    String   @unique
  botName     String?
  isActive    Boolean  @default(true)
  welcomeMessage String?
  notifyNewOrder    Boolean @default(true)
  notifyLowStock    Boolean @default(true)
  notifyPayment     Boolean @default(true)
  notifyDailyReport Boolean @default(true)
  dailyReportTime   String  @default("09:00")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chats TelegramChat[]
}

model TelegramChat {
  id        String   @id @default(cuid())
  chatId    String   @unique
  chatType  String   @default("private")
  username  String?
  firstName String?
  lastName  String?
  isActive  Boolean  @default(true)

  botConfigId String
  botConfig   TelegramBotConfig @relation(fields: [botConfigId], references: [id], onDelete: Cascade)

  userId     String?  @unique
  user       User?    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([botConfigId])
  @@index([chatId])
}

// ─── PRODUCT BATCH / EXPIRY TRACKING (FIFO/FEFO) ─

model ProductBatch {
  id           String    @id @default(cuid())
  batchNumber  String
  productId    String
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId  String
  warehouse    Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  quantity     Float     @default(0)
  initialQty   Float     @default(0)
  costPrice    Float     @default(0)
  manufactureDate DateTime?
  expiryDate   DateTime?
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id])
  purchaseId   String?
  notes        String?
  isActive     Boolean   @default(true)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  orderItems OrderItem[]

  @@index([productId])
  @@index([warehouseId])
  @@index([expiryDate])
  @@index([batchNumber])
}

// ─── DELIVERY MANAGEMENT ─────────────────────────

enum DeliveryStatus {
  PREPARING
  LOADED
  IN_TRANSIT
  DELIVERED
  PARTIALLY_DELIVERED
  RETURNED
  CANCELLED
}

model Delivery {
  id            String         @id @default(cuid())
  docNumber     String         @unique
  date          DateTime       @default(now())
  orderId       String?   @unique
  order         Order?    @relation(fields: [orderId], references: [id])
  customerId    String?
  customer      Customer?      @relation(fields: [customerId], references: [id])
  warehouseId   String
  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
  driverName    String?
  driverPhone   String?
  vehicleNumber String?
  status        DeliveryStatus @default(PREPARING)
  address       String?
  latitude      Float?
  longitude     Float?
  notes         String?
  totalWeight   Float?
  deliveredAt   DateTime?

  items         DeliveryItem[]
  route         DeliveryRoute?

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([orderId])
  @@index([customerId])
  @@index([warehouseId])
  @@index([status])
  @@index([date])
}

model DeliveryItem {
  id          String   @id @default(cuid())
  deliveryId  String
  delivery    Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Float
  deliveredQty Float  @default(0)
  notes       String?

  @@index([deliveryId])
  @@index([productId])
}

model DeliveryRoute {
  id              String   @id @default(cuid())
  deliveryId      String   @unique
  delivery        Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  totalDistance   Float    @default(0)
  estimatedTime   Int?
  optimizedOrder  String?
  startedAt       DateTime?
  completedAt     DateTime?
  polyline        String?

  stops           DeliveryRouteStop[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([deliveryId])
}

model DeliveryRouteStop {
  id          String         @id @default(cuid())
  routeId     String
  route       DeliveryRoute  @relation(fields: [routeId], references: [id], onDelete: Cascade)
  stopOrder   Int
  customerId  String?
  customer    Customer?      @relation(fields: [customerId], references: [id])
  address     String?
  latitude    Float?
  longitude   Float?
  plannedAt   DateTime?
  arrivedAt   DateTime?
  status      DeliveryStatus @default(PREPARING)
  notes       String?

  @@index([routeId])
  @@index([stopOrder])
}

// ─── SALES AGENT COMMISSION ──────────────────────

model SalesAgent {
  id          String   @id @default(cuid())
  userId      String?  @unique
  user        User?    @relation(fields: [userId], references: [id])
  name        String
  phone       String?
  commissionRate Float @default(0)
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      Order[]
  commissions Commission[]

  @@index([userId])
  @@index([name])
}

model Commission {
  id          String   @id @default(cuid())
  agentId     String
  agent       SalesAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  orderId     String?  @unique
  order       Order?   @relation(fields: [orderId], references: [id])
  amount      Float
  rate        Float
  saleAmount  Float
  isPaid      Boolean  @default(false)
  paidDate    DateTime?
  period      String?
  notes       String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([agentId])
  @@index([orderId])
  @@index([isPaid])
}

// ─── CUSTOMER LOYALTY PROGRAM ───────────────────

enum LoyaltyTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

model LoyaltyProgram {
  id                String      @id @default(cuid())
  name              String
  description       String?
  isActive          Boolean     @default(true)
  pointsPerDollar   Float       @default(1)
  bronzeThreshold   Int         @default(0)
  bronzeDiscount    Float       @default(0)
  silverThreshold   Int         @default(500)
  silverDiscount    Float       @default(5)
  goldThreshold     Int         @default(2000)
  goldDiscount      Float       @default(10)
  platinumThreshold Int         @default(5000)
  platinumDiscount  Float       @default(15)

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model LoyaltyAccount {
  id            String       @id @default(cuid())
  customerId    String       @unique
  customer      Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  points        Int          @default(0)
  totalEarned   Int          @default(0)
  totalRedeemed Int          @default(0)
  tier          LoyaltyTier  @default(BRONZE)
  isActive      Boolean      @default(true)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  transactions  LoyaltyTransaction[]

  @@index([customerId])
  @@index([tier])
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  accountId   String
  account     LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type        String
  points      Int
  orderId     String?
  description String?
  expiresAt   DateTime?

  createdAt   DateTime @default(now())

  @@index([accountId])
  @@index([type])
  @@index([createdAt])
}

// ─── EXPENSE MANAGEMENT ──────────────────────────

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model ExpenseCategory {
  id          String   @id @default(cuid())
  name        String
  icon        String?
  color       String?
  budget      Float?
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expenses    Expense[]

  @@index([name])
}

model Expense {
  id          String        @id @default(cuid())
  categoryId  String
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  amount      Float
  currency    String        @default("UZS")
  description String?
  date        DateTime      @default(now())
  status      ExpenseStatus @default(PENDING)
  receiptUrl  String?
  requestedBy String?
  approvedBy  String?
  approvedAt  DateTime?
  notes       String?

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([categoryId])
  @@index([status])
  @@index([date])
}

// ─── PRINT TEMPLATE BUILDER ──────────────────────

enum TemplateType {
  INVOICE
  RECEIPT
  WAYBILL
  ACT
  CUSTOM
}

model PrintTemplate {
  id          String       @id @default(cuid())
  name        String
  type        TemplateType @default(INVOICE)
  content     String
  isActive    Boolean      @default(true)
  isDefault   Boolean      @default(false)
  paperSize   String       @default("A4")
  orientation String       @default("portrait")

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([type])
  @@index([isActive])
}

// ─── 1C ACCOUNTING INTEGRATION ───────────────────

enum SyncStatus {
  PENDING
  SYNCING
  COMPLETED
  FAILED
}

model OneCSyncLog {
  id          String     @id @default(cuid())
  entityType  String
  entityId    String?
  action      String
  status      SyncStatus @default(PENDING)
  payload     String?
  response    String?
  error       String?
  syncedAt    DateTime?

  createdAt   DateTime   @default(now())

  @@index([entityType])
  @@index([status])
  @@index([createdAt])
}

model OneCConfig {
  id          String   @id @default(cuid())
  apiUrl      String
  apiKey      String
  isActive    Boolean  @default(true)
  syncInterval Int?
  lastSyncAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── CONTRACT MANAGEMENT ─────────────────────────

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  TERMINATED
}

model Contract {
  id            String         @id @default(cuid())
  contractNumber String        @unique
  title         String
  type          String
  status        ContractStatus @default(DRAFT)
  startDate     DateTime
  endDate       DateTime?
  value         Float?
  currency      String         @default("USD")
  description   String?
  terms         String?

  customerId    String?
  customer      Customer?      @relation(fields: [customerId], references: [id])
  supplierId    String?
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])

  attachments   ContractAttachment[]
  payments      ContractPayment[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([customerId])
  @@index([supplierId])
  @@index([status])
  @@index([endDate])
}

model ContractAttachment {
  id          String   @id @default(cuid())
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String
  fileType    String?
  fileSize    Int?
  description String?

  createdAt   DateTime @default(now())

  @@index([contractId])
}

model ContractPayment {
  id          String   @id @default(cuid())
  contractId  String
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  amount      Float
  currency    String   @default("USD")
  dueDate     DateTime
  paidDate    DateTime?
  isPaid      Boolean  @default(false)
  notes       String?

  createdAt   DateTime @default(now())

  @@index([contractId])
  @@index([isPaid])
  @@index([dueDate])
}

// ─── AI DEMAND FORECAST ──────────────────────────

model DemandForecast {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String?
  period      String
  predictedQty Float
  confidence  Float    @default(0)
  algorithm   String
  inputData   String?
  month       Int
  year        Int

  createdAt   DateTime @default(now())

  @@unique([productId, warehouseId, month, year])
  @@index([productId])
  @@index([month, year])
}
