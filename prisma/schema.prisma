generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── PRODUCT DOMAIN ──────────────────────────────

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Folder {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Unit {
  id        String    @id @default(cuid())
  name      String    // "Dona (rulon)", "m²", "Karobka"
  shortName String    // "dona", "m²", "karobka"
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id             String   @id @default(cuid())
  name           String
  sku            String?  @unique
  barcode        String?  @unique
  barcodeType    String   @default("EAN13") // EAN13, Code128, UPC
  imageUrl       String?

  sellPrice      Float    @default(0)
  wholesalePrice Float    @default(0)
  minPrice       Float    @default(0)

  categoryId     String?
  category       Category? @relation(fields: [categoryId], references: [id])
  folderId       String?
  folder         Folder?   @relation(fields: [folderId], references: [id])
  unitId         String?
  unit           Unit?     @relation(fields: [unitId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  stockEntries        StockEntry[]
  transferItems       TransferItem[]
  inventoryAuditItems InventoryAuditItem[]
  priceListItems      PriceListItem[]
  purchaseItems       PurchaseItem[]
  orderItems          OrderItem[]

  @@index([categoryId])
  @@index([name])
}

// ─── WAREHOUSE DOMAIN ────────────────────────────

model Warehouse {
  id        String   @id @default(cuid())
  name      String
  address   String?
  district  String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockEntries     StockEntry[]
  transfersFrom    Transfer[]          @relation("TransferFrom")
  transfersTo      Transfer[]          @relation("TransferTo")
  inventoryAudits  InventoryAudit[]
  inventoryAuditItems InventoryAuditItem[]
  purchases        Purchase[]
  orders           Order[]
  users            User[]
  userRequests     UserRequest[]
}

model StockEntry {
  id          String   @id @default(cuid())
  quantity    Float    @default(0)
  reserved    Float    @default(0)
  costPrice   Float    @default(0)

  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, warehouseId])
  @@index([warehouseId])
}

// ─── TRANSFER DOMAIN ─────────────────────────────

enum TransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

model Transfer {
  id                String         @id @default(cuid())
  docNumber         String         @unique
  date              DateTime       @default(now())
  responsiblePerson String?
  status            TransferStatus @default(PENDING)

  fromWarehouseId   String
  fromWarehouse     Warehouse      @relation("TransferFrom", fields: [fromWarehouseId], references: [id])
  toWarehouseId     String
  toWarehouse       Warehouse      @relation("TransferTo", fields: [toWarehouseId], references: [id])

  items             TransferItem[]

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([date])
}

model TransferItem {
  id         String   @id @default(cuid())
  quantity   Float

  transferId String
  transfer   Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])

  @@index([transferId])
}

// ─── INVENTORY AUDIT DOMAIN ─────────────────────

enum AuditStatus {
  IN_PROGRESS
  COMPLETED
}

model InventoryAudit {
  id                String      @id @default(cuid())
  docNumber         String      @unique
  date              DateTime    @default(now())
  responsiblePerson String?
  status            AuditStatus @default(IN_PROGRESS)

  warehouseId       String
  warehouse         Warehouse   @relation(fields: [warehouseId], references: [id])

  items             InventoryAuditItem[]

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([warehouseId])
}

model InventoryAuditItem {
  id          String         @id @default(cuid())
  expectedQty Float          @default(0)
  actualQty   Float          @default(0)
  difference  Float          @default(0)
  reason      String?

  auditId     String
  audit       InventoryAudit @relation(fields: [auditId], references: [id], onDelete: Cascade)
  productId   String
  product     Product        @relation(fields: [productId], references: [id])
  warehouseId String
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id])

  @@index([auditId])
  @@index([productId])
  @@index([warehouseId])
}

// ─── PRICE LIST DOMAIN ──────────────────────────

enum PriceListType {
  SALE
  PURCHASE
}

model PriceList {
  id        String        @id @default(cuid())
  name      String
  type      PriceListType @default(SALE)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  items     PriceListItem[]
}

model PriceListItem {
  id          String    @id @default(cuid())
  price       Float

  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])

  @@unique([priceListId, productId])
}

// ─── CUSTOMER DOMAIN ────────────────────────────

model CustomerGroup {
  id              String   @id @default(cuid())
  name            String
  description     String?
  defaultDiscount Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customers       Customer[]
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

model Customer {
  id          String         @id @default(cuid())
  fullName    String
  companyName String?
  phone       String?
  region      String?
  status      CustomerStatus @default(ACTIVE)
  balanceUSD  Float          @default(0)
  balanceUZS  Float          @default(0)

  groupId     String?
  group       CustomerGroup? @relation(fields: [groupId], references: [id])

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  transactions CustomerTransaction[]
  orders       Order[]

  @@index([groupId])
  @@index([fullName])
}

enum TransactionType {
  DEBT
  PAYMENT
}

model CustomerTransaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Float
  currency    String          @default("USD") // USD or UZS
  date        DateTime        @default(now())
  dueDate     DateTime?
  description String?

  customerId  String
  customer    Customer        @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt   DateTime        @default(now())

  @@index([customerId])
  @@index([date])
}

// ─── SUPPLIER DOMAIN ────────────────────────────

enum SupplierStatus {
  ACTIVE
  INACTIVE
}

model Supplier {
  id            String         @id @default(cuid())
  name          String
  contactPerson String?
  phone         String?
  category      String?
  status        SupplierStatus @default(ACTIVE)
  balanceUSD    Float          @default(0)
  balanceUZS    Float          @default(0)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  transactions  SupplierTransaction[]
  purchases     Purchase[]

  @@index([name])
}

model SupplierTransaction {
  id          String          @id @default(cuid())
  type        TransactionType
  amount      Float
  currency    String          @default("USD")
  date        DateTime        @default(now())
  dueDate     DateTime?
  description String?

  supplierId  String
  supplier    Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  createdAt   DateTime        @default(now())

  @@index([supplierId])
  @@index([date])
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum SubscriptionStatus {
  PENDING
  PAID
  OVERDUE
}

enum UserRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model UserRequest {
  id           String            @id @default(cuid())
  name         String
  phone        String            @unique
  email        String?
  password     String
  warehouseId  String?
  warehouse    Warehouse?        @relation(fields: [warehouseId], references: [id])
  status       UserRequestStatus @default(PENDING)
  note         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([status])
  @@index([warehouseId])
}

model User {
  id          String   @id @default(cuid())
  name        String?
  email       String?  @unique
  phone       String?  @unique
  password    String
  role        UserRole @default(STAFF)
  isActive    Boolean  @default(true)
  permissions String[] @default([])

  warehouseId String?
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions     Subscription[]
  userNotifications UserNotification[]
  settings          UserSettings?

  @@index([warehouseId])
  @@index([phone])
}

// ─── USER SETTINGS ───────────────────────────────

model UserSettings {
  id                  String  @id @default(cuid())
  userId              String  @unique
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailNotifications  Boolean @default(true)
  pushNotifications   Boolean @default(false)
  lowStockAlerts      Boolean @default(true)
  orderNotifications  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id        String   @id @default(cuid())
  amount    Float
  currency  String   @default("USD")
  dueDate   DateTime
  isPaid    Boolean  @default(false)
  paidDate  DateTime?
  note      String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([dueDate])
}

// ─── PURCHASE DOMAIN (KIRIM) ────────────────────

enum PurchaseStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

model Purchase {
  id          String         @id @default(cuid())
  docNumber   String         @unique
  date        DateTime       @default(now())
  supplierId  String
  supplier    Supplier       @relation(fields: [supplierId], references: [id])
  warehouseId String
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id])
  totalAmount Float          @default(0)
  status      PurchaseStatus @default(DRAFT)
  notes       String?

  items       PurchaseItem[]

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([supplierId])
  @@index([warehouseId])
  @@index([date])
}

model PurchaseItem {
  id         String   @id @default(cuid())
  purchaseId String
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Float
  price      Float    // Cost price at the time of purchase
  total      Float

  @@index([purchaseId])
  @@index([productId])
}

// ─── SALES DOMAIN (SAVDO) ───────────────────────

enum OrderStatus {
  DRAFT
  COMPLETED
  CANCELLED
  RETURNED
}

model Order {
  id            String      @id @default(cuid())
  docNumber     String      @unique
  date          DateTime    @default(now())
  customerId    String?
  customer      Customer?   @relation(fields: [customerId], references: [id])
  warehouseId   String
  warehouse     Warehouse   @relation(fields: [warehouseId], references: [id])
  totalAmount   Float       @default(0)
  discount      Float       @default(0)
  finalAmount   Float       @default(0)
  status        OrderStatus @default(COMPLETED)
  paymentMethod String?     // CASH, CARD, TRANSFER
  notes         String?

  items         OrderItem[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([customerId])
  @@index([warehouseId])
  @@index([date])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Float
  price     Float   // Selling price at the time of sale
  total     Float

  @@index([orderId])
  @@index([productId])
}

// ─── CASHBOX DOMAIN (KASSA) ─────────────────────

enum CashboxType {
  CASH
  CARD
  BANK
}

model Cashbox {
  id           String            @id @default(cuid())
  name         String            // "Asosiy Kassa", "Humo", "Uzcard", "Tranzit"
  type         CashboxType       @default(CASH)
  currency     String            @default("UZS")
  balance      Float             @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  transactions CashTransaction[]
}

enum CashTransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

model CashTransaction {
  id          String              @id @default(cuid())
  cashboxId   String
  cashbox     Cashbox             @relation(fields: [cashboxId], references: [id], onDelete: Cascade)
  type        CashTransactionType
  amount      Float
  date        DateTime            @default(now())
  referenceId String?             // Order ID or Purchase ID etc
  description String?

  createdAt   DateTime            @default(now())

  @@index([cashboxId])
  @@index([date])
}

// ─── EXCHANGE RATE ──────────────────────────────

model ExchangeRate {
  id        String   @id @default(cuid())
  currency  String   @unique @default("USD")
  rate      Float    // masalan: 12500
  date      DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── ADMIN NOTIFICATIONS ─────────────────────────

model AdminNotification {
  id        String   @id @default(cuid())
  type      String   // "new_user_request" | "order" | "stock_low" | "info"
  title     String
  message   String
  link      String?  // Click qilganda qaerga o'tishi
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isRead])
  @@index([createdAt])
}

// ─── USER NOTIFICATIONS ──────────────────────────

model UserNotification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "product_transfer" | "info" | "warning"
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}
